  "onRowSelected": "{{\n    GetAssetStatus.run();\n    CheckAssetOnSale.run(() => {\n        const alreadySold = CheckAssetOnSale.data.length > 0;\n        const status = GetAssetStatus.data[0]?.status_name;\n\n        if (alreadySold) {\n            showAlert(\n                \"Asset already on Sales Order: \" + CheckAssetOnSale.data[0].sale_ref,\n                \"warning\"\n            );\n        }\n        else if (status !== \"Available for Sale\") {\n            showAlert(\n                \"Asset not available for sale — current status: \" + status,\n                \"warning\"\n            );\n        }\n\n        storeValue(\"assetBlocked\", false);\n        storeValue(\"reason\", \"\");\n    });\n}}\n",
