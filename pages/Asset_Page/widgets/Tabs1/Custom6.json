    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\">\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\nbody{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f4f0;color:#1a1a1a;font-size:14px;line-height:1.5;padding:1rem}\n.section{background:#fff;border:0.5px solid rgba(0,0,0,0.12);border-radius:12px;padding:1.25rem;margin-bottom:1rem}\n.section-title{font-size:11px;font-weight:500;color:#5f5e5a;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:1rem;display:flex;align-items:center;gap:6px}\n.section-title i{font-size:14px}\n.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}\n.form-group{display:flex;flex-direction:column;gap:4px}\n.form-group label{font-size:12px;color:#5f5e5a}\nselect,input[type=text]{width:100%;font-size:13px;padding:7px 10px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;background:#fff;color:#1a1a1a;outline:none}\nselect:focus,input[type=text]:focus{border-color:#1a3c2e}\n.actions{display:flex;gap:8px;justify-content:flex-end;margin-top:1rem}\n.btn{font-size:13px;padding:7px 14px;border-radius:8px;border:0.5px solid rgba(0,0,0,0.2);background:transparent;color:#1a1a1a;cursor:pointer}\n.btn-primary{background:#1a3c2e;color:#fff;border:none;font-size:13px;padding:7px 14px;border-radius:8px;cursor:pointer}\n.info-banner{font-size:12px;padding:7px 12px;border-radius:8px;margin-bottom:1rem;display:flex;align-items:center;gap:7px;background:#E1F5EE;color:#085041}\n.filter-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}\n</style>\n</head>\n<body>\n\n<div class=\"section\">\n  <div class=\"section-title\"><i class=\"ti ti-tool\" aria-hidden=\"true\"></i>Remove a part from this asset</div>\n  <div class=\"form-grid\">\n    <div class=\"form-group\">\n      <label>Part type</label>\n      <select id=\"sel_part_type\">\n        <option value=\"\">— select —</option>\n        <option value=\"1\">RAM</option>\n        <option value=\"2\">SSD / HDD</option>\n        <option value=\"3\">Battery</option>\n        <option value=\"4\">Screen / LCD</option>\n        <option value=\"5\">Keyboard</option>\n        <option value=\"6\">Palm Rest</option>\n        <option value=\"7\">Bottom Case</option>\n        <option value=\"8\">Motherboard</option>\n      </select>\n    </div>\n    <div class=\"form-group\">\n      <label>Condition grade</label>\n      <select id=\"sel_grade\">\n        <option value=\"\">— select —</option>\n        <option value=\"A\">A — Excellent</option>\n        <option value=\"B\">B — Good</option>\n        <option value=\"C\">C — Fair</option>\n        <option value=\"F\">F — Faulty / scrap</option>\n      </select>\n    </div>\n    <div class=\"form-group\">\n      <label>Spec</label>\n      <input type=\"text\" id=\"inp_spec\" placeholder=\"e.g. 16GB DDR4, 512GB NVMe\" />\n    </div>\n    <div class=\"form-group\">\n      <label>Serial number (if present)</label>\n      <input type=\"text\" id=\"inp_serial\" placeholder=\"Optional\" />\n    </div>\n    <div class=\"form-group\">\n      <label>Removed by</label>\n      <input type=\"text\" id=\"inp_removed_by\" placeholder=\"Technician name\" />\n    </div>\n    <div class=\"form-group\">\n      <label>Notes</label>\n      <input type=\"text\" id=\"inp_removal_notes\" placeholder=\"Any notes about condition or removal\" />\n    </div>\n  </div>\n  <div class=\"actions\">\n    <button class=\"btn\" onclick=\"clearForm()\">Clear</button>\n    <button class=\"btn-primary\" onclick=\"logRemoval()\">Log part removal</button>\n  </div>\n</div>\n\n<div class=\"section\">\n  <div class=\"section-title\"><i class=\"ti ti-circle-plus\" aria-hidden=\"true\"></i>Add a part from stock</div>\n  <div class=\"info-banner\"><i class=\"ti ti-clock-hour-4\" aria-hidden=\"true\"></i>Showing oldest stock first — select from the top of the list to stay R2v3 FIFO compliant.</div>\n  <div class=\"filter-row\">\n    <div class=\"form-group\">\n      <label>Filter by part type</label>\n      <select id=\"sel_stock_filter\" onchange=\"filterStock()\">\n        <option value=\"\">— all types —</option>\n        <option value=\"RAM\">RAM</option>\n        <option value=\"SSD / HDD\">SSD / HDD</option>\n        <option value=\"Battery\">Battery</option>\n        <option value=\"Screen / LCD\">Screen / LCD</option>\n        <option value=\"Keyboard\">Keyboard</option>\n        <option value=\"Palm Rest\">Palm Rest</option>\n        <option value=\"Bottom Case\">Bottom Case</option>\n        <option value=\"Motherboard\">Motherboard</option>\n      </select>\n    </div>\n    <div class=\"form-group\">\n      <label>Min grade</label>\n      <select id=\"sel_grade_filter\" onchange=\"filterStock()\">\n        <option value=\"\">Any grade</option>\n        <option value=\"A\">A only</option>\n        <option value=\"AB\">A or B</option>\n        <option value=\"ABC\">A, B or C</option>\n      </select>\n    </div>\n  </div>\n</div>\n\n<script>\nfunction filterStock() {\n  var typeFilter = document.getElementById('sel_stock_filter').value;\n  var gradeFilter = document.getElementById('sel_grade_filter').value;\n  appsmith.updateModel({\n    stock_type_filter: typeFilter,\n    stock_grade_filter: gradeFilter\n  });\n  setTimeout(function() {\n    appsmith.triggerEvent('onFilterStock');\n  }, 300);\n}\n\nfunction logRemoval() {\n  var part_type_id = document.getElementById('sel_part_type').value;\n  var condition_grade = document.getElementById('sel_grade').value;\n  var spec = document.getElementById('inp_spec').value;\n  var serial_number = document.getElementById('inp_serial').value;\n  var removed_by = document.getElementById('inp_removed_by').value;\n  var removal_notes = document.getElementById('inp_removal_notes').value;\n  if (!part_type_id || !condition_grade) {\n    alert('Please select a part type and grade.');\n    return;\n  }\n  appsmith.updateModel({\n    hp_part_type_id: part_type_id,\n    hp_condition_grade: condition_grade,\n    hp_spec: spec,\n    hp_serial: serial_number,\n    hp_removed_by: removed_by,\n    hp_notes: removal_notes\n  });\n  setTimeout(function() {\n    appsmith.triggerEvent('onLogRemoval');\n  }, 500);\n  clearForm();\n}\n\nfunction clearForm() {\n  document.getElementById('sel_part_type').value = '';\n  document.getElementById('sel_grade').value = '';\n  document.getElementById('inp_spec').value = '';\n  document.getElementById('inp_serial').value = '';\n  document.getElementById('inp_removed_by').value = '';\n  document.getElementById('inp_removal_notes').value = '';\n}\n\nappsmith.onReady(function() {\n  appsmith.onModelChange(function(model) {});\n});\n</script>\n</body>\n</html>\n",
