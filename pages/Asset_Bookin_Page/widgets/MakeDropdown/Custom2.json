:7px 14px;border-radius:8px;border:0.5px solid rgba(0,0,0,0.2);background:transparent;color:#1a1a1a;cursor:pointer}\n.btn-primary{background:#1a3c2e;color:#fff;border:none;font-size:13px;padding:7px 14px;border-radius:8px;cursor:pointer}\n.btn-primary:disabled{background:#888;cursor:not-allowed}\n.count{font-size:13px;color:#5f5e5a}\ninput[type=checkbox]{width:16px;height:16px;cursor:pointer;accent-color:#1a3c2e}\n.info{font-size:12px;color:#5f5e5a;margin-top:0.5rem}\n.db-yes{font-size:11px;font-weight:500;padding:2px 9px;border-radius:20px;background:#FCEBEB;color:#791F1F}\n.db-no{font-size:11px;font-weight:500;padding:2px 9px;border-radius:20px;background:#F1EFE8;color:#5F5E5A}\n</style>\n</head>\n<body>\n\n<div class=\"section\">\n  <div class=\"section-title\"><i class=\"ti ti-upload\" aria-hidden=\"true\"></i>Bulk upload from manifest</div>\n  <div class=\"upload-area\" onclick=\"document.getElementById('file_input').click()\">\n    <i class=\"ti ti-file-spreadsheet\" aria-hidden=\"true\"></i>\n    <p>Click to select your Excel manifest</p>\n    <span>Accepts .xlsx files — headers: Item Type, Make, Model, Serial, Cost, Data Bearing</span>\n  </div>\n  <input type=\"file\" id=\"file_input\" accept=\".xlsx\" onchange=\"handleFile(this)\" />\n  <p class=\"info\" id=\"file_name\"></p>\n</div>\n\n<div class=\"section\" id=\"preview_section\" style=\"display:none\">\n  <div class=\"section-title\"><i class=\"ti ti-table\" aria-hidden=\"true\"></i>Manifest preview</div>\n  <div style=\"overflow-x:auto\">\n    <table>\n      <thead>\n        <tr>\n          <th><input type=\"checkbox\" id=\"chk_all\" onchange=\"toggleAll(this)\" /></th>\n          <th>Item type</th>\n          <th>Make</th>\n          <th>Model</th>\n          <th>Serial</th>\n          <th>Cost</th>\n          <th>Data bearing</th>\n          <th>Asset ref</th>\n          <th>Status</th>\n        </tr>\n      </thead>\n      <tbody id=\"preview_body\"></tbody>\n    </table>\n  </div>\n  <div class=\"actions\">\n    <span class=\"count\" id=\"row_count\"></span>\n    <button class=\"btn\" onclick=\"clearUpload()\">Clear</button>\n    <button class=\"btn btn-primary\" id=\"btn_book\" onclick=\"bookSelected()\" disabled>Book selected</button>\n  </div>\n</div>\n\n<script>\nvar parsedRows = [];\n\nfunction handleFile(input) {\n  var file = input.files[0];\n  if (!file) return;\n  document.getElementById('file_name').textContent = 'Loaded: ' + file.name;\n  var reader = new FileReader();\n  reader.onload = function(e) {\n    var data = new Uint8Array(e.target.result);\n    var wb = XLSX.read(data, {type:'array'});\n    var ws = wb.Sheets[wb.SheetNames[0]];\n    var rows = XLSX.utils.sheet_to_json(ws, {defval:''});\n    parsedRows = rows.map(function(r, i) {\n      var dbRaw = (r['Data Bearing'] || r['data bearing'] || r['data_bearing'] || '').toString().trim().toLowerCase();\n      return {\n        idx: i,\n        item_type: (r['Item Type'] || r['item type'] || r['item_type'] || '').trim(),\n        make: (r['Make'] || r['make'] || '').trim(),\n        model: (r['Model'] || r['model'] || '').trim(),\n        serial: (r['Serial'] || r['serial'] || '').trim(),\n        cost: (r['Cost'] || r['cost'] || 0),\n        data_bearing: dbRaw === 'yes' || dbRaw === 'true' || dbRaw === '1',\n        asset_ref: '',\n        status: 'pending'\n      };\n    }).filter(function(r) { return r.item_type || r.make || r.model || r.serial; });\n    renderPreview();\n  };\n  reader.readAsArrayBuffer(file);\n}\n\nfunction renderPreview() {\n  var tbody = document.getElementById('preview_body');\n  if (!parsedRows.length) {\n    tbody.innerHTML = '<tr><td colspan=\"9\" style=\"text-align:center;padding:2rem;color:#888\">No rows found</td></tr>';\n    return;\n  }\n  tbody.innerHTML = parsedRows.map(function(r) {\n    var statusCell = r.status === 'booked'\n      ? '<span class=\"ok-badge\">Booked</span>'\n      : r.status === 'error'\n      ? '<span class=\"err-badge\">Error</span>'\n      : '—';\n    var refCell = r.asset_ref ? '<span class=\"ref-badge\">' + r.asset_ref + '</span>' : '—';\n    var dbCell = r.data_bearing\n      ? '<span class=\"db-yes\">Yes</span>'\n      : '<span class=\"db-no\">No</span>';\n    return '<tr class=\"' + (r.status === 'error' ? 'error-row' : '') + '\">' +\n      '<td><input type=\"checkbox\" class=\"row-chk\" data-idx=\"' + r.idx + '\" ' + (r.status === 'booked' ? 'disabled checked' : '') + ' onchange=\"updateCount()\" /></td>' +\n      '<td>' + (r.item_type || '—') + '</td>' +\n      '<td>' + (r.make || '—') + '</td>' +\n      '<td>' + (r.model || '—') + '</td>' +\n      '<td style=\"font-family:monospace;font-size:12px\">' + (r.serial || '—') + '</td>' +\n      '<td>£' + (parseFloat(r.cost)||0).toFixed(2) + '</td>' +\n      '<td>' + dbCell + '</td>' +\n      '<td>' + refCell + '</td>' +\n      '<td>' + statusCell + '</td>' +\n      '</tr>';\n  }).join('');\n  document.getElementById('preview_section').style.display = 'block';\n  updateCount();\n}\n\nfunction toggleAll(chk) {\n  var boxes = document.querySelectorAll('.row-chk:not(:disabled)');\n  boxes.forEach(function(b) { b.checked = chk.checked; });\n  updateCount();\n}\n\nfunction updateCount() {\n  var checked = document.querySelectorAll('.row-chk:checked').length;\n  var total = parsedRows.filter(function(r) { return r.status !== 'booked'; }).length;\n  document.getElementById('row_count').textContent = checked + ' of ' + total + ' selected';\n  document.getElementById('btn_book').disabled = checked === 0;\n}\n\nfunction getSelectedRows() {\n  var selected = [];\n  document.querySelectorAll('.row-chk:checked').forEach(function(chk) {\n    var idx = parseInt(chk.getAttribute('data-idx'));\n    var row = parsedRows.find(function(r) { return r.idx === idx; });\n    if (row) selected.push(row);\n  });\n  return selected;\n}\n\nfunction bookSelected() {\n  var selected = getSelectedRows();\n  if (!selected.length) return;\n  appsmith.updateModel({ upload_rows: selected });\n  setTimeout(function() {\n    appsmith.triggerEvent('onBookUploaded');\n  }, 300);\n}\n\nfunction clearUpload() {\n  parsedRows = [];\n  document.getElementById('file_input').value = '';\n  document.getElementById('file_name').textContent = '';\n  document.getElementById('preview_section').style.display = 'none';\n}\n\nfunction markBooked(refs) {\n  refs.forEach(function(ref, i) {\n    if (parsedRows[i]) {\n      parsedRows[i].asset_ref = ref;\n      parsedRows[i].status = 'booked';\n    }\n  });\n  renderPreview();\n}\n\nappsmith.onReady(function() {\n  appsmith.onModelChange(function(model) {\n    if (model.bookedRefs && model.bookedRefs.length) {\n      markBooked(model.bookedRefs);\n    }\n  });\n});\n</script>\n</body>\n</html>\n",
    "js": "import React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\n\nconst Button = ({ children, className, ...props }) => (\n  <button className={className} {...props}>\n    {children}\n  </button>\n);\n\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n\n  const handleNext = () => {\n    setCurrentIndex((prevIndex) => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n\n  return (\n    <div className=\"app\">\n      <div className=\"tip-container\">\n        <div className=\"tip-header\">\n          <h2>Custom Widget</h2>\n          <div>{currentIndex + 1} / {appsmith.model.tips.length}</div>\n        </div>\n        <div className=\"content\">{appsmith.model.tips[currentIndex]}</div>\n      </div>\n      <div className=\"button-container\">\n        <Button className=\"primary\" onClick={handleNext}>Next Tip</Button>\n        <Button className=\"reset\" disabled={currentIndex === 0} onClick={handleReset}>Reset</Button>\n      </div>\n    </div>\n  );\n}\n\nappsmith.onReady(() => {\n/*\n\t * This handler function will get called when parent application is ready.\n\t * Initialize your component here\n\t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n\t */\n    ReactDOM.render(<App />, document.getElementById(\"root\"));\n});"
  },
